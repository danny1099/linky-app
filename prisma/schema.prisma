generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model links {
  id           String    @id @default(cuid())
  title        String
  qr_url       String
  original_url String
  short_url    String    @unique
  slug         String?
  owner_id     String
  timeLapse    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  tags         String?
  Clicks       clicks[]
}

model clicks {
  id        String   @id @default(cuid())
  linkId    String
  mode      String
  origin    String?
  device    String?
  ip        String?
  link      links    @relation(fields: [linkId], references: [id])
  createdAt DateTime @default(now())
}
