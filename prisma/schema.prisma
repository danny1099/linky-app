generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model links {
  id           String   @id @default(cuid())
  title        String
  qr           String
  original_url String
  short_url    String
  slug         String?  @unique
  tags         String[]
  owner_id     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  Clicks       clicks[]
}

model clicks {
  id        String   @id @default(cuid())
  linkId    String
  origin    String?
  device    String
  ip        String?
  link      links    @relation(fields: [linkId], references: [id])
  createdAt DateTime @default(now())
}
